# Copy to config.env and edit:
#   cp config.env.example config.env

# Domains (must match DNS and existing certificates)
REMOTE_DOMAIN="remote.example.com"
MDM_DOMAIN="mdm.example.com"
CERTBOT_EMAIL="admin@example.com"

# Backend HTTPS ports (localhost only)
REMOTE_HTTPS_PORT="9443"
MDM_HTTPS_PORT="8443"

# Paths
REMOTE_DIR="/root/h-mdm-remote-control"
HMDM_DOCKER_DIR="/root/hmdm-docker"

# Where MDM stores Let's Encrypt files inside hmdm-docker (adjust if different)
HMDM_LETSENCRYPT_DIR="${HMDM_DOCKER_DIR}/volumes/letsencrypt"

# Host webroots for HTTP-01 challenges (port 80, host nginx)
REMOTE_ACME_WEBROOT="/var/www/letsencrypt/remote"
MDM_ACME_WEBROOT="/var/www/letsencrypt/mdm"

# Public ports Janus still needs (ufw reminder in setup output)
JANUS_HTTPS_PORT="8089"
JANUS_WSS_PORT="8989"
RTP_UDP_RANGE="10000:10500"
